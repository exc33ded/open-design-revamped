{
  "name": "open-design",
  "version": "0.14.2",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "description": "Local-first, BYOK design app.",
  "license": "Apache-2.0",
  "bin": {
    "od": "./apps/daemon/bin/od.mjs"
  },
  "scripts": {
    "dev": "node dev.mjs",
    "tools-dev": "pnpm exec tools-dev",
    "typecheck": "pnpm -r --workspace-concurrency=4 --if-present run typecheck"
  },
  "devDependencies": {
    "@open-design/components": "workspace:*",
    "@open-design/daemon": "workspace:*",
    "@open-design/tools-dev": "workspace:*",
    "@types/node": "20.19.39",
    "tsx": "4.22.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "~24",
    "pnpm": ">=10.33.2 <11"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "5.0.6",
      "devalue": "5.8.1",
      "fast-uri": "3.1.2",
      "hono": "4.12.19",
      "ip-address": "10.2.0",
      "postcss": "8.5.15",
      "protobufjs": "8.4.0",
      "qs": "6.15.2",
      "tmp": "0.2.7",
      "yaml": "2.9.0"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "core-js",
      "electron",
      "electron-winstaller",
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  }
}
